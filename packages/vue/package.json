  "description": "龙鱼图标Vue组件库.",
  "type": "module",
  "keywords": [
    "icon",
    "svg",
    "vue",
    "vue3"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+http://175.178.3.38/lyNpm/ly-icons.git",
    "directory": "packages/vue"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.bundle.js",
  "module": "dist/index.js",
  "types": "dist/types/components.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "dist/types/components.d.ts"
      ]
    }
  },
  "sideEffects": false,
  "scripts": {
