    "@pnpm/logger": "^4.0.0",
    "@types/fs-extra": "^9.0.13",
    "@types/node": "^17.0.36",
    "@types/prettier": "^2.6.3",
    "camelcase": "^6.3.0",
    "chalk": "^5.0.1",
    "cheerio": "1.0.0-rc.11",
    "consola": "^2.15.3",
    "esbuild": "^0.14.42",
    "esbuild-plugin-globals": "^0.1.1",
    "fast-glob": "^3.2.11",
    "fs-extra": "^10.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.6.2",
    "svgo": "^2.8.0",
    "tsx": "^3.4.2",
    "typescript": "^4.7.2",
    "unplugin-vue": "^2.2.0",
    "vue": "^3.2.36",
    "vue-tsc": "^0.35.0"
  }
